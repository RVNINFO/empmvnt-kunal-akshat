{
  "_version": "1.82.0",
  "sap.app": {
    "id": "com.syensqo.hr.empmovementform",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "597c03ab-e162-4e24-aecc-958dbc018781"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/syq-empglobalmobility-srv/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "empmovementform-manage": {
          "semanticObject": "empmovementform",
          "action": "manage",
          "title": "{{empmovementform-manage.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.unified": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.fe.core": {},
        "sap.fe.macros": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.syensqo.hr.empmovementform.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/visibility-rules.css"
        }
      ]
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "EmploymentMovementList",
          "target": "EmploymentMovementList"
        },
        {
          "pattern": "EmploymentMovement({key}):?query:",
          "name": "EmploymentMovementObjectPage",
          "target": "EmploymentMovementObjectPage"
        }
      ],
      "targets": {
        "EmploymentMovementList": {
          "type": "Component",
          "id": "EmploymentMovementList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/EmploymentMovement",
              "variantManagement": "Page",
              "navigation": {
                "EmploymentMovement": {
                  "detail": {
                    "route": "EmploymentMovementObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "actions": {
                    "CreateMovement": {
                      "press": "com.syensqo.hr.empmovementform.ext.CreateMovementHandler.createMovement",
                      "text": "{i18n>create}",
                      "requiresSelection": false,
                      "global": true,
                      "visible": true,
                      "enabled": true
                    }
                  }
                }
              },
              "initialLoad": "Disabled"
            }
          }
        },
        "EmploymentMovementObjectPage": {
          "type": "Component",
          "id": "EmploymentMovementObjectPage",
          "name": "sap.fe.core.fpm",
          "viewLevel": 1,
          "options": {
            "settings": {
              "viewName": "com.syensqo.hr.empmovementform.view.EmploymentMovementObjectPage",
              "contextPath": "/EmploymentMovement"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "empglobalmobily"
  }
}
