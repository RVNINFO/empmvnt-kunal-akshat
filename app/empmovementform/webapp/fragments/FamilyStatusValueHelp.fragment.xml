<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcValueHelpContent="sap.ui.mdc.valuehelp.content">
    <mdc:ValueHelp
        id="familyStatusValueHelp"
        delegate='{"name":"com/syensqo/hr/empmovementform/ext/MovementTypeValueHelpDelegate","payload":{"collectionPath":"/ValueHelp","keyPath":"ID","descriptionPath":"name","searchKeys":["code","name"],"typeFilter":"5","openOnClick":true,"openOnTab":true}}'>
        <mdc:typeahead>
            <mdcvh:Popover id="familyStatusValueHelpPopover">
                <mdcValueHelpContent:MTable
                    id="familyStatusValueHelpTable"
                    keyPath="ID"
                    descriptionPath="name"
                    caseSensitive="false"
                    useAsValueHelp="true" />
            </mdcvh:Popover>
        </mdc:typeahead>
    </mdc:ValueHelp>
</core:FragmentDefinition>