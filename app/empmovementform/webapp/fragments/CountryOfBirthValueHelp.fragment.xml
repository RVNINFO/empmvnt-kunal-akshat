<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:mdc="sap.ui.mdc"
    xmlns:mdcvh="sap.ui.mdc.valuehelp"
    xmlns:mdcValueHelpContent="sap.ui.mdc.valuehelp.content">
    <mdc:ValueHelp
        id="countryOfBirthValueHelp"
        delegate='{"name":"com/syensqo/hr/empmovementform/ext/MovementTypeValueHelpDelegate","payload":{"collectionPath":"/CountryVH","keyPath":"code","descriptionPath":"name","searchKeys":["code","name"],"openOnClick":true,"openOnTab":true}}'>
        <mdc:typeahead>
            <mdcvh:Popover id="countryOfBirthValueHelpPopover">
                <mdcValueHelpContent:MTable
                    id="countryOfBirthValueHelpTable"
                    keyPath="code"
                    descriptionPath="name"
                    caseSensitive="false"
                    useAsValueHelp="true" />
            </mdcvh:Popover>
        </mdc:typeahead>
    </mdc:ValueHelp>
</core:FragmentDefinition>