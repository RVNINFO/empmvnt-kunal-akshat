<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:mdc="sap.ui.mdc">
    <mdc:Field
        id="hostCountryField"
        value="{hostCountry_code}"
        display="Description"
        editMode="{= ${ui>/isEditable} ? 'Editable' : 'Display' }"
        valueHelp="hostCountryValueHelp"
        visible="{= ${visibility>/fields/hostCountry_code} !== false }" />
</core:FragmentDefinition>