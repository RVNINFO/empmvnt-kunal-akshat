<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:mdc="sap.ui.mdc">
    <mdc:Field
        id="countryOfBirthField"
        value="{countryOfBirth_code}"
        display="Description"
        editMode="{= ${ui>/isEditable} ? 'Editable' : 'Display' }"
        valueHelp="countryOfBirthValueHelp"
        visible="{= ${visibility>/fields/countryOfBirth_code} !== false }" />
</core:FragmentDefinition>