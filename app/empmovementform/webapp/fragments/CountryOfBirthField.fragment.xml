<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns:macros="sap.fe.macros">
    <macros:Field
        id="countryOfBirthMacroField"
        metaPath="/EmploymentMovement/countryOfBirth_code"
        value="{countryOfBirth_code}"
        description="{countryOfBirth/name}"
        visible="{= ${visibility>/fields/countryOfBirth_code} !== false }"
        readOnly="{= !${ui>/isEditable} }" />
</core:FragmentDefinition>